<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevCoreAI4 - TikTok Downloader</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        body { font-family: sans-serif; background: #121212; color: white; text-align: center; padding: 50px; }
        input { padding: 10px; width: 300px; border-radius: 5px; border: none; }
        button { padding: 10px 20px; background: #00ff00; border: none; cursor: pointer; font-weight: bold; }
        .result { margin-top: 30px; padding: 20px; border: 1px solid #333; display: inline-block; }
        video { max-width: 100%; width: 300px; }
    </style>
</head>
<body>
    <h1>TikTok Downloader 👾</h1>
    <form action="/download" method="POST">
        <input type="text" name="url" placeholder="Paste URL TikTok di sini..." required>
        <button type="submit">Download</button>
    </form>

    <% if (error) { %>
        <p style="color: red;"><%= error %></p>
    <% } %>

    <% if (result) { %>
        <div class="result">
            <h3>Hasil Scan DevCoreAI4:</h3>
            <p>Title: <%= result.title || 'Video' %></p>
            <!-- Menampilkan video jika ada -->
            <video controls>
                <source src="<%= result.video[0] %>" type="video/mp4">
            </video>
            <br><br>
            <a href="<%= result.video[0] %>" download style="color: cyan;">Klik di sini jika download otomatis gagal</a>
        </div>
    <% } %>
</body>
</html>
